{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroLag",
  "version": "0.1.0",
  "identifier": "org.zerolag.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZeroLag",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "Productivity",
    "shortDescription": "Local-first voice intelligence",
    "externalBin": ["binaries/zerolag-sidecar"],
    "resources": {
      "../../sidecar/src": "sidecar/src",
      "../../sidecar/.bundle-deps/node_modules": "sidecar/node_modules",
      "../../sidecar/.env": "sidecar/.env"
    }
  }
}
