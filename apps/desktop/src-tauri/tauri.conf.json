{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroLag",
  "version": "0.1.0",
  "identifier": "org.zerolag.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ZeroLag",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      },
      {
        "label": "recorder-overlay",
        "title": "ZeroLag Recording",
        "url": "index.html?overlay=1",
        "width": 300,
        "height": 80,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "focus": false,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Local-first voice intelligence"
  }
}
