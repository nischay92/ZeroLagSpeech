# Web (copy to apps/web/.env.local when running outside Docker)
NEXT_PUBLIC_API_URL=http://localhost:8000

# API (copy to apps/api/.env when running outside Docker)
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
WEB_ORIGIN=http://localhost:3000

# PostgreSQL (use the Supabase connection string in hosted environments)
POSTGRES_DB=zerolag
POSTGRES_USER=zerolag
POSTGRES_PASSWORD=zerolag
POSTGRES_PORT=55432
DATABASE_URL=postgresql+asyncpg://zerolag:zerolag@127.0.0.1:55432/zerolag
DATABASE_REQUIRED=false
DATABASE_ECHO=false

